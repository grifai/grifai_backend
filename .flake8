[flake8]
max-line-length = 120
extend-ignore =
    # E203: whitespace before ':' — совместимо с black
    E203,
    # W503: line break before binary operator — стиль black
    W503
per-file-ignores =
    # legacy-файлы — не трогаем
    app/llm/prompts.py:E501
    app/bot/client.py:E501,F541
    app/llm/openai_provider.py:E231
    app/config.py:F401
    app/main.py:F401,F811,F541
    app/services/digest.py:F401
    app/services/search.py:F541
    app/memory/rag.py:E203
exclude =
    .git,
    __pycache__,
    alembic/versions,
    data/,
    jarvis_cache/,
    .env
