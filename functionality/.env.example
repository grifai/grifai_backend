# LLM API Keys
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Database
DATABASE_URL=postgresql+asyncpg://grif:grif_secret@localhost:5432/grif_db
DATABASE_SYNC_URL=postgresql+psycopg2://grif:grif_secret@localhost:5432/grif_db

# Redis
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# Tools
TAVILY_API_KEY=tvly-...
TELEGRAM_BOT_TOKEN=...

# App settings
APP_ENV=development
SECRET_KEY=change-me-in-production
DEBUG=true

# Rate limiting defaults (per plan)
MAX_ACTIVE_AGENTS=10
MAX_TOKENS_PER_DAY=500000
MAX_RECURRING_AGENTS=5
