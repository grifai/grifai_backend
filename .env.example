## Example env for grif_ai
# Copy to .env and fill values locally (do NOT commit .env)

# Telegram
TG_API_ID=123456
TG_API_HASH=your-telegram-api-hash

# OpenAI
OPENAI_KEY=sk-...

# VK (optional)
VK_TOKEN=

# Anthropic / Claude (optional)
ANTHROPIC_KEY=
CLAUDE_API_URL=https://api.anthropic.com/v1/messages

# Datastores
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379
QDRANT_URL=http://localhost:6333

# ElevenLabs (TTS)
ELEVENLABS_KEY=

# VK (optional — leave empty to disable)
VK_TOKEN=vk1.a.LN1wUcf9NOv6JVWymPSx-_X8u1kPbQZKP_47dTWst7itMTopxa7Kw6HUWqoeAMq3D1xh7ccd5BH8NHXWRAiuJZxIotNpZ95q9eLgxQu4qGHD3iJB8jVL0XrzyAk3F38jr-_16C3804AvRW0QAXrg_vL3ovqYfaGXbzFwzaDDJ1MeF8B2Zn0fFDn9AVisX76s3NkJPYxxkSZxQctKWDixSw&expires_in=0&user_id=754617197 

# Max messenger (optional — leave empty to disable)
